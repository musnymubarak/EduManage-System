generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String           @id @default(uuid())
  username                 String           @unique
  email                    String?          @unique
  password                 String
  role                     UserRole
  status                   UserStatus       @default(ACTIVE)
  fullName                 String
  phoneNumber              String?
  createdBy                String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  lastLogin                DateTime?
  collectedPayments        FeePayment[]     @relation("FeeCollector")
  collectedPartialPayments PartialPayment[] @relation("PartialFeeCollector")
  authoredHistory          TodoHistory[]    @relation("HistoryChanger")
  assignedTodos            Todo[]           @relation("AssignedTodos")
  createdTodos             Todo[]           @relation("CreatedTodos")

  @@map("users")
}

model Student {
  id                    String                 @id @default(uuid())
  admissionNumber       String                 @unique
  fullName              String
  nameWithInitials      String
  dateOfBirth           DateTime
  gender                Gender
  bloodGroup            BloodGroup?
  religion              String
  ethnicity             String
  nationality           String                 @default("Sri Lankan")
  nic                   String?                @unique
  birthCertificateNo    String?                @unique
  address               String
  city                  String
  district              String
  province              String
  postalCode            String?
  homePhone             String?
  email                 String?
  classId               String
  admissionDate         DateTime               @default(now())
  previousSchool        String?
  guardianName          String
  guardianRelationship  String
  guardianNIC           String
  guardianAddress       String?
  guardianOccupation    String?
  guardianEmail         String?
  emergencyContactName  String
  emergencyContactPhone String
  emergencyRelationship String
  medicalConditions     String?
  allergies             String?
  profilePhoto          String?
  status                String                 @default("ACTIVE")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  leavingDate           DateTime?
  leavingReason         String?
  leavingReasonOther    String?
  indexNumber           String?                @unique
  dsDivision            String?
  gnDivision            String?
  mobileNumber          String?
  guardianPhones        String[]               @default([])
  examMarks             ExamMark[]
  feePayments           FeePayment[]
  attendance            StudentAttendance[]
  documents             StudentDocument[]
  medicalHistory        StudentMedicalHistory?
  class                 Class                  @relation(fields: [classId], references: [id])

  @@map("students")
}

model StudentDocument {
  id           String   @id @default(uuid())
  studentId    String
  documentType String
  fileName     String
  fileUrl      String
  uploadedAt   DateTime @default(now())
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_documents")
}

model StudentMedicalHistory {
  id                  String   @id @default(uuid())
  studentId           String   @unique
  bloodGroup          String?
  rhFactor            String?
  height              Float?
  weight              Float?
  bmi                 Float?
  vision              String?
  wearingGlasses      Boolean  @default(false)
  squintEye           String?
  sight               String?
  hearingProblem      String?
  oralHygiene         String?
  dentalCaries        Boolean  @default(false)
  gumDisorder         Boolean  @default(false)
  foodDrugAllergy     Boolean  @default(false)
  allergyDetails      String?
  skinProblem         Boolean  @default(false)
  skinProblemDetails  String?
  respiratoryProblem  Boolean  @default(false)
  respiratoryDetails  String?
  undergoneSurgery    Boolean  @default(false)
  surgeryDetails      String?
  nervousProblem      Boolean  @default(false)
  nervousDetails      String?
  gastritis           Boolean  @default(false)
  otherSickness       String?
  immunizationGiven   Boolean  @default(false)
  vaccineBcg          Boolean  @default(false)
  vaccinePolio        Boolean  @default(false)
  vaccineRubella      Boolean  @default(false)
  vaccineAtd          Boolean  @default(false)
  vaccineHpv          Boolean  @default(false)
  immunizationDetails String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_medical_history")
}

model Teacher {
  id                 String                 @id @default(uuid())
  employeeNumber     String                 @unique
  fullName           String
  nameWithInitials   String
  dateOfBirth        DateTime
  gender             Gender
  nic                String                 @unique
  address            String
  city               String
  district           String
  province           String
  email              String?
  specialization     String?
  experience         String?
  joinedDate         DateTime               @default(now())
  designation        String
  employmentType     String
  profilePhoto       String?
  status             String                 @default("ACTIVE")
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  basicSalary        Float                  @default(0)
  postalCode         String?
  dsDivision         String?
  gnDivision         String?
  phoneNumbers       String[]               @default([])
  leavingDate        DateTime?
  leavingReason      String?
  leavingReasonOther String?
  attendance         TeacherAttendance[]
  documents          TeacherDocument[]
  memos              TeacherMemo[]
  qualifications     TeacherQualification[]
  schedules          TeacherSchedule[]

  @@map("teachers")
}

model TeacherQualification {
  id            String  @id @default(uuid())
  teacherId     String
  qualification String
  institution   String
  year          Int
  field         String?
  teacher       Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_qualifications")
}

model TeacherDocument {
  id           String   @id @default(uuid())
  teacherId    String
  documentType String
  fileName     String
  fileUrl      String
  uploadedAt   DateTime @default(now())
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_documents")
}

model TeacherMemo {
  id        String   @id @default(uuid())
  teacherId String
  title     String
  content   String
  date      DateTime @default(now())
  createdBy String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_memos")
}

model Staff {
  id                 String            @id @default(uuid())
  employeeNumber     String            @unique
  fullName           String
  nameWithInitials   String
  dateOfBirth        DateTime
  gender             Gender
  nic                String            @unique
  drivingLicenseNo   String?           @unique
  address            String
  city               String
  district           String
  province           String
  postalCode         String?
  email              String?
  department         StaffDepartment
  designation        String
  employmentType     String
  joinedDate         DateTime          @default(now())
  basicSalary        Float             @default(0)
  profilePhoto       String?
  status             String            @default("ACTIVE")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  dsDivision         String?
  gnDivision         String?
  phoneNumbers       String[]          @default([])
  leavingDate        DateTime?
  leavingReason      String?
  leavingReasonOther String?
  attendance         StaffAttendance[]
  documents          StaffDocument[]
  duties             StaffDuty[]
  salaryHistory      StaffSalary[]

  @@map("staff")
}

model StaffSalary {
  id            String        @id @default(uuid())
  staffId       String
  month         String
  basicSalary   Float
  allowances    Float         @default(0)
  deductions    Float         @default(0)
  netSalary     Float
  paymentDate   DateTime      @default(now())
  paymentMethod PaymentMethod @default(CASH)
  receiptNumber String?       @unique
  remarks       String?
  paidBy        String
  createdAt     DateTime      @default(now())
  staff         Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, month])
  @@map("staff_salaries")
}

model StaffDocument {
  id           String   @id @default(uuid())
  staffId      String
  documentType String
  fileName     String
  fileUrl      String
  uploadedAt   DateTime @default(now())
  staff        Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_documents")
}

model StaffDuty {
  id           String     @id @default(uuid())
  staffId      String
  title        String
  description  String?
  status       DutyStatus @default(ASSIGNED)
  assignedDate DateTime   @default(now())
  dueDate      DateTime?
  completedAt  DateTime?
  remarks      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_duties")
}

model StaffAttendance {
  id        String           @id @default(uuid())
  staffId   String
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  markedBy  String
  createdAt DateTime         @default(now())
  staff     Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("staff_attendance")
}

model Class {
  id           String              @id @default(uuid())
  name         String              @unique
  grade        Int
  section      String?
  capacity     Int                 @default(30)
  academicYear String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  exams        Exam[]
  attendance   StudentAttendance[]
  students     Student[]
  schedules    TeacherSchedule[]

  @@map("classes")
}

model StudentAttendance {
  id        String           @id @default(uuid())
  studentId String
  classId   String
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  markedBy  String
  createdAt DateTime         @default(now())
  class     Class            @relation(fields: [classId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@map("student_attendance")
}

model TeacherAttendance {
  id        String           @id @default(uuid())
  teacherId String
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  markedBy  String
  createdAt DateTime         @default(now())
  teacher   Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, date])
  @@map("teacher_attendance")
}

model TeacherSchedule {
  id        String    @id @default(uuid())
  teacherId String
  classId   String
  subject   String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  room      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  class     Class     @relation(fields: [classId], references: [id])
  teacher   Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_schedules")
}

model FeePayment {
  id              String           @id @default(uuid())
  studentId       String
  feeType         FeeType
  amount          Float
  paidAmount      Float            @default(0)
  balance         Float
  status          PaymentStatus
  dueDate         DateTime
  paymentDate     DateTime?
  paymentMethod   PaymentMethod?
  receiptNumber   String?          @unique
  month           String?
  academicYear    String
  remarks         String?
  collectedBy     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  collector       User             @relation("FeeCollector", fields: [collectedBy], references: [id])
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  partialPayments PartialPayment[]

  @@map("fee_payments")
}

model PartialPayment {
  id            String        @id @default(uuid())
  feePaymentId  String
  amount        Float
  paymentDate   DateTime
  paymentMethod PaymentMethod
  receiptNumber String?
  collectedBy   String
  remarks       String?
  createdAt     DateTime      @default(now())
  collector     User          @relation("PartialFeeCollector", fields: [collectedBy], references: [id])
  feePayment    FeePayment    @relation(fields: [feePaymentId], references: [id], onDelete: Cascade)

  @@map("partial_payments")
}

model Exam {
  id           String     @id @default(uuid())
  name         String
  term         ExamTerm
  classId      String
  subject      String
  examDate     DateTime
  totalMarks   Float
  passingMarks Float
  examFee      Float?
  academicYear String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  marks        ExamMark[]
  class        Class      @relation(fields: [classId], references: [id])

  @@map("exams")
}

model ExamMark {
  id            String   @id @default(uuid())
  examId        String
  studentId     String
  marksObtained Float
  grade         String?
  remarks       String?
  enteredBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@map("exam_marks")
}

model Inventory {
  id           String            @id @default(uuid())
  itemName     String
  category     InventoryCategory
  quantity     Int
  minQuantity  Int               @default(10)
  unit         String
  location     String?
  status       InventoryStatus   @default(AVAILABLE)
  purchaseDate DateTime?
  price        Float?
  supplier     String?
  remarks      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@map("inventory")
}

model Donation {
  id            String        @id @default(uuid())
  donorName     String
  donorContact  String?
  donorAddress  String?
  amount        Float
  donationType  String
  purpose       String?
  paymentMethod PaymentMethod @default(CASH)
  receiptNumber String?       @unique
  date          DateTime      @default(now())
  remarks       String?
  recordedBy    String
  createdAt     DateTime      @default(now())

  @@map("donations")
}

model Expenditure {
  id            String              @id @default(uuid())
  date          DateTime
  category      ExpenditureCategory
  description   String
  amount        Float
  vendor        String?
  billNumber    String?
  paymentMethod PaymentMethod
  remarks       String?
  recordedBy    String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("expenditures")
}

model Todo {
  id          String        @id @default(uuid())
  title       String
  description String
  priority    TodoPriority  @default(MEDIUM)
  status      TodoStatus    @default(TODO)
  category    String?
  createdBy   String
  assignedTo  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  completedAt DateTime?
  history     TodoHistory[]
  assignee    User?         @relation("AssignedTodos", fields: [assignedTo], references: [id])
  creator     User          @relation("CreatedTodos", fields: [createdBy], references: [id])

  @@map("todos")
}

model TodoHistory {
  id        String   @id @default(uuid())
  todoId    String
  action    String
  oldValue  String?
  newValue  String?
  changedBy String
  timestamp DateTime @default(now())
  changer   User     @relation("HistoryChanger", fields: [changedBy], references: [id])
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@map("todo_history")
}

model AcademicYear {
  id        String   @id @default(uuid())
  year      String   @unique
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("academic_years")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  FINANCE_OFFICER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
}

enum StaffDepartment {
  ADMINISTRATION
  SECURITY
  CLEANING
  MAINTENANCE
  KITCHEN
  TRANSPORT
  LIBRARY
  OTHER
}

enum DutyStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  SICK_LEAVE
  EXCUSED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum FeeType {
  MONTHLY
  EXAM
  ADMISSION
  OTHER
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ONLINE
  CHEQUE
}

enum ExamTerm {
  FIRST_TERM
  SECOND_TERM
  THIRD_TERM
}

enum InventoryCategory {
  FURNITURE
  STATIONERY
  ELECTRONICS
  SPORTS
  BOOKS
  OTHER
}

enum InventoryStatus {
  AVAILABLE
  IN_USE
  DAMAGED
  OUT_OF_STOCK
}

enum ExpenditureCategory {
  SALARIES
  UTILITIES
  MAINTENANCE
  SUPPLIES
  TRANSPORTATION
  EVENTS
  OTHER
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
